# Configuration du Bot Discord
# Copie ce fichier en .env et remplace par tes tokens

# Token Discord du bot (OBLIGATOIRE)
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Clé API Groq pour les fonctionnalités IA (OBLIGATOIRE)
GROQ_API_KEY=your_groq_api_key_here

# Base de données PostgreSQL (OPTIONNEL - pour production)
# Si non défini, le bot utilisera SQLite en local (learning_streak.db)
# Format: postgresql://user:password@host:port/dbname
# DATABASE_URL=postgresql://user:password@host:port/dbname
